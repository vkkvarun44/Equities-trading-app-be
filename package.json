{
  "name": "tradeflow-api",
  "version": "1.0.0",
  "description": "Production-ready stock trading platform API with Alpaca Broker integration",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
